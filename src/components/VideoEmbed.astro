---
interface Props {
  url: string;
}

const { url } = Astro.props;

function getYouTubeId(url: string): string | null {
  const match = url.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
  );
  return match ? match[1] : null;
}

const youtubeId = getYouTubeId(url);
const isShort = url.includes("/shorts/");
const isSCWidget = url.includes("w.soundcloud.com/player");
const isSCPage = !isSCWidget && url.includes("soundcloud.com");

// For SoundCloud page URLs, use oEmbed to resolve the correct embed
let scEmbedHtml = "";
if (isSCPage) {
  const cleanUrl = url.split("?")[0];
  try {
    const res = await fetch(`https://soundcloud.com/oembed?format=json&url=${encodeURIComponent(cleanUrl)}`);
    if (res.ok) {
      const data = await res.json();
      scEmbedHtml = data.html;
    }
  } catch (_) {}
  if (!scEmbedHtml) {
    scEmbedHtml = `<iframe width="100%" height="300" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=${encodeURIComponent(cleanUrl)}&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true"></iframe>`;
  }
}
---

{youtubeId && (
  <div class:list={["video-embed", { short: isShort }]}>
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
      title="YouTube video"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    />
  </div>
)}

{isSCWidget && (
  <div class="sc-embed">
    <iframe
      width="100%"
      height="300"
      scrolling="no"
      frameborder="no"
      allow="autoplay"
      src={url}
    />
  </div>
)}

{isSCPage && (
  <div class="sc-embed" set:html={scEmbedHtml} />
)}

<style>
  .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    margin: 1rem 0;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
  }

  .video-embed.short {
    padding-bottom: 177.78%;
  }

  .video-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .sc-embed {
    margin: 1rem 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .sc-embed iframe {
    display: block;
    border: 0;
  }
</style>
